{
  "name": "agrohelp-project",
  "version": "1.0.0",
  "description": "AgroHelp - Smart Farming Assistant with Weather Prediction and Disease Detection",
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend-api && npm run dev",
